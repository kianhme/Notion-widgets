<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>لیست کارها </title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@100..900&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#0f0f0f;
    font-family:"Vazirmatn",sans-serif;
    color:white;
    display:flex;
    justify-content:center;
    align-items:center;
    min-height:100vh;
    padding:20px;
    direction:rtl;
}

.widget{
    width:370px;
    background:#1b1b1b;
    border-radius:30px;
    padding:24px;
    box-shadow:
    0 10px 40px rgba(0,0,0,0.35);
}

.title{
    font-size:24px;
    font-weight:700;
    margin-bottom:20px;
}

.progress-container{
    width:100%;
    height:14px;
    background:#2b2b2b;
    border-radius:999px;
    overflow:hidden;
    margin-bottom:10px;
}

.progress-bar{
    height:100%;
    width:0%;
    background:linear-gradient(
        90deg,
        #4ade80,
        #22c55e
    );
    transition:0.3s;
}

.progress-text{
    font-size:14px;
    opacity:0.75;
    margin-bottom:24px;
}

.todo-list{
    display:flex;
    flex-direction:column;
    gap:12px;
    margin-bottom:22px;
}

.todo-item{
    background:#262626;
    border-radius:20px;
    padding:15px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    transition:0.25s;
    gap:10px;
}

.todo-right{
    display:flex;
    align-items:center;
    gap:12px;
    flex:1;
}

.check{
    width:24px;
    height:24px;
    border-radius:50%;
    border:2px solid #666;
    cursor:pointer;
    transition:0.25s;
    flex-shrink:0;
}

.todo-text{
    font-size:16px;
    line-height:1.7;
    word-break:break-word;
}

.completed{
    background:#173322;
}

.completed .check{
    background:#4ade80;
    border-color:#4ade80;
}

.completed .todo-text{
    text-decoration:line-through;
    opacity:0.6;
}

.delete-btn{
    width:34px;
    height:34px;
    border:none;
    border-radius:12px;
    background:#343434;
    color:#bbb;
    cursor:pointer;
    transition:0.2s;
    font-size:18px;
    flex-shrink:0;
}

.delete-btn:hover{
    background:#ff4d4d;
    color:white;
}

.controls{
    display:flex;
    gap:12px;
}

.control-btn{
    flex:1;
    height:56px;
    border:none;
    border-radius:18px;
    background:#2d2d2d;
    color:white;
    font-size:30px;
    cursor:pointer;
    transition:0.2s;
    font-family:"Vazirmatn",sans-serif;
}

.control-btn:hover{
    background:#3a3a3a;
}

.input-popup{
    position:fixed;
    inset:0;
    background:rgba(0,0,0,0.6);
    display:none;
    justify-content:center;
    align-items:center;
    padding:20px;
}

.popup-box{
    width:340px;
    background:#1d1d1d;
    border-radius:28px;
    padding:22px;
}

.popup-title{
    font-size:20px;
    font-weight:700;
    margin-bottom:16px;
}

.popup-input{
    width:100%;
    height:54px;
    border:none;
    outline:none;
    border-radius:16px;
    background:#2b2b2b;
    color:white;
    padding:0 16px;
    font-size:15px;
    margin-bottom:16px;
    font-family:"Vazirmatn",sans-serif;
}

.popup-input::placeholder{
    color:#999;
}

.popup-buttons{
    display:flex;
    gap:10px;
}

.popup-btn{
    flex:1;
    height:50px;
    border:none;
    border-radius:16px;
    cursor:pointer;
    font-size:15px;
    transition:0.2s;
    font-family:"Vazirmatn",sans-serif;
}

.cancel-btn{
    background:#333;
    color:white;
}

.cancel-btn:hover{
    background:#444;
}

.add-btn{
    background:#4ade80;
    color:black;
    font-weight:700;
}

.add-btn:hover{
    transform:scale(1.03);
}

.empty{
    text-align:center;
    opacity:0.5;
    padding:18px 0;
    font-size:15px;
}

</style>

</head>

<body>

<div class="widget">

    <div class="title">
      📌 لیست کارهای امروز 
    </div>

    <div class="progress-container">
        <div class="progress-bar" id="progressBar"></div>
    </div>

    <div class="progress-text" id="progressText">
        0٪ انجام شده
    </div>

    <div class="todo-list" id="todoList"></div>

    <div class="controls">

        <button
            class="control-btn"
            onclick="removeLastTodo()"
        >
            −
        </button>

        <button
            class="control-btn"
            onclick="openPopup()"
        >
            +
        </button>

    </div>

</div>

<div class="input-popup" id="popup">

    <div class="popup-box">

        <div class="popup-title">
            تسک جدید
        </div>

        <input
            type="text"
            id="taskInput"
            class="popup-input"
            placeholder="مثلا درس خوندن..."
        >

        <div class="popup-buttons">

            <button
                class="popup-btn cancel-btn"
                onclick="closePopup()"
            >
                بستن
            </button>

            <button
                class="popup-btn add-btn"
                onclick="addTodo()"
            >
                افزودن
            </button>

        </div>

    </div>

</div>

<script>

let todos =
JSON.parse(localStorage.getItem("todos")) || [];

const todoList =
document.getElementById("todoList");

const progressBar =
document.getElementById("progressBar");

const progressText =
document.getElementById("progressText");

function saveTodos(){

    localStorage.setItem(
        "todos",
        JSON.stringify(todos)
    );

}

function renderTodos(){

    todoList.innerHTML = "";

    if(todos.length === 0){

        todoList.innerHTML = `
            <div class="empty">
                هنوز کاری اضافه نشده
            </div>
        `;

    }

    todos.forEach((todo,index)=>{

        const item =
        document.createElement("div");

        item.className =
        todo.completed
        ? "todo-item completed"
        : "todo-item";

        item.innerHTML = `

            <div class="todo-right">

                <div
                    class="check"
                    onclick="toggleTodo(${index})"
                ></div>

                <div class="todo-text">
                    ${todo.text}
                </div>

            </div>

            <button
                class="delete-btn"
                onclick="deleteTodo(${index})"
            >
                ×
            </button>

        `;

        todoList.appendChild(item);

    });

    updateProgress();

    saveTodos();

}

function updateProgress(){

    const total = todos.length;

    const completed =
    todos.filter(
        todo => todo.completed
    ).length;

    let percent = 0;

    if(total > 0){

        percent =
        (completed / total) * 100;

    }

    progressBar.style.width =
    percent + "%";

    progressText.innerText =
    Math.round(percent)
    + "٪ انجام شده";

}

function openPopup(){

    document.getElementById("popup")
    .style.display = "flex";

    document.getElementById("taskInput")
    .focus();

}

function closePopup(){

    document.getElementById("popup")
    .style.display = "none";

    document.getElementById("taskInput")
    .value = "";

}

function addTodo(){

    const input =
    document.getElementById("taskInput");

    const text =
    input.value.trim();

    if(text === "") return;

    todos.push({

        text:text,
        completed:false

    });

    renderTodos();

    closePopup();

}

function toggleTodo(index){

    todos[index].completed =
    !todos[index].completed;

    renderTodos();

}

function deleteTodo(index){

    todos.splice(index,1);

    renderTodos();

}

function removeLastTodo(){

    if(todos.length > 0){

        todos.pop();

        renderTodos();

    }

}

document
.getElementById("taskInput")
.addEventListener("keydown",(e)=>{

    if(e.key === "Enter"){

        addTodo();

    }

});

renderTodos();

</script>

</body>
</html>
